# Copy to deploy/.env and adjust. Used by docker-compose.prefect.yml.

# Postgres password for the Prefect metadata DB
POSTGRES_PASSWORD=prefect

# URL the browser uses to reach the Prefect API (set to the VM's address/host)
PREFECT_UI_API_URL=http://localhost:4200/api

# Work pool the worker serves and deployments target
PREFECT_WORK_POOL=digitizer-pool

# Host paths bind-mounted into the worker
RAW_SCANS_MOUNT=/mnt/digital-library/raw-scans
OUTPUT_DIR=../output
CACHE_DIR=../.cache
