# Copy to deploy/.env and adjust. Used by docker-compose.yml.

# Host paths bind-mounted into the container
RAW_SCANS_MOUNT=/mnt/digital-library/raw-scans
OUTPUT_DIR=../output
CACHE_DIR=../.cache

# EvilFlowers Catalog import (used by `publish-catalog`; see [catalog] in
# configs/pipeline.toml). A long-lived API key (a Bearer JWT) for the catalog
# instance — create one via POST /api/v1/api_keys. Leave blank to disable.
EVILFLOWERS_API_KEY=
